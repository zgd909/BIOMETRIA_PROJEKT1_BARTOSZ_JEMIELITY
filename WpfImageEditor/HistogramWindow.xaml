<Window x:Class="WpfImageEditor.HistogramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Histogram" Height="480" Width="760" MinHeight="360" MinWidth="560"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <RadioButton x:Name="RbGray"  Content="Szarość"   Margin="6,0" Padding="8,4"
                             IsChecked="True" Checked="Channel_Checked"/>
                <RadioButton x:Name="RbRed"   Content="Czerwony"  Margin="6,0" Padding="8,4"
                             Checked="Channel_Checked"/>
                <RadioButton x:Name="RbGreen" Content="Zielony"   Margin="6,0" Padding="8,4"
                             Checked="Channel_Checked"/>
                <RadioButton x:Name="RbBlue"  Content="Niebieski" Margin="6,0" Padding="8,4"
                             Checked="Channel_Checked"/>
            </StackPanel>
        </Border>

        <Canvas x:Name="HistCanvas" Grid.Row="1" ClipToBounds="True" Margin="0"/>

        <Border Grid.Row="2" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock x:Name="TxtMean"   FontSize="11" Margin="0,0,24,0"/>
                <TextBlock x:Name="TxtMode"   FontSize="11" Margin="0,0,24,0"/>
                <TextBlock x:Name="TxtMin"    FontSize="11" Margin="0,0,24,0"/>
                <TextBlock x:Name="TxtMax"    FontSize="11" Margin="0,0,24,0"/>
                <TextBlock x:Name="TxtPixels" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
