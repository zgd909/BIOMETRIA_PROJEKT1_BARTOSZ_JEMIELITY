<Window x:Class="WpfImageEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Przetwarzanie obrazów projekt" Height="750" Width="1200" MinHeight="600" MinWidth="900">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="Label">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="0,2,0,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button Content="Otwórz obraz"        Click="OpenImage_Click"      Padding="10,4"/>
            <Separator/>
            <Button Content="Zapisz obraz"        Click="SaveImage_Click"      Padding="10,4"/>
            <Separator/>
            <Button Content="Histogram"           Click="ShowHistogram_Click"  Padding="10,4"/>
            <Button Content="Projekcje"           Click="ShowProjections_Click" Padding="10,4"/>
            <Separator/>
            <Button Content="Cofnij filtr (Undo)" Click="Undo_Click"           Padding="10,4"
                    x:Name="BtnUndo" IsEnabled="False"/>
            <Button Content="Resetuj do oryginału" Click="Reset_Click"         Padding="10,4"/>
            <Separator/>
            <Label x:Name="LblHistory" Content="Historia: 0 kroków"/>
        </ToolBar>

        <Grid Grid.Row="1" Margin="6,6,6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderThickness="1" BorderBrush="Gray">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Content="Obraz oryginalny" Style="{StaticResource SectionLabel}"
                           HorizontalAlignment="Center"/>
                    <Viewbox Grid.Row="1" Stretch="Uniform">
                        <Image x:Name="ImgOriginal"/>
                    </Viewbox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"/>

            <Border Grid.Column="2" BorderThickness="1" BorderBrush="Gray">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Content="Obraz edytowany" Style="{StaticResource SectionLabel}"
                           HorizontalAlignment="Center"/>
                    <Viewbox Grid.Row="1" Stretch="Uniform">
                        <Image x:Name="ImgEdited"/>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" BorderThickness="0,1,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Margin="6,4">

                    <GroupBox Header="Operacje pikselowe">
                        <StackPanel>
                            <Button Content="Odcienie szarości" Click="Grayscale_Click"/>
                            <Button Content="Negatyw"           Click="Negative_Click"/>

                            <Label Content="Jasność:" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SliderBrightness" Minimum="-255" Maximum="255" Value="0"
                                        Width="130" VerticalAlignment="Center"/>
                                <Label x:Name="LblBrightness" Grid.Column="1" Content="0" FontSize="10"/>
                            </Grid>
                            <Button Content="Zastosuj jasność" Click="ApplyBrightness_Click"/>

                            <Label Content="Kontrast (mnożnik):" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SliderContrast" Minimum="0.1" Maximum="4.0" Value="1.0"
                                        Width="130" VerticalAlignment="Center"/>
                                <Label x:Name="LblContrast" Grid.Column="1" Content="1.0" FontSize="10"/>
                            </Grid>
                            <Button Content="Zastosuj kontrast" Click="ApplyContrast_Click"/>

                            <Label Content="Próg binaryzacji:" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SliderThreshold" Minimum="0" Maximum="255" Value="128"
                                        Width="130" VerticalAlignment="Center"/>
                                <Label x:Name="LblThreshold" Grid.Column="1" Content="128" FontSize="10"/>
                            </Grid>
                            <Button Content="Binaryzacja" Click="Binarize_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Filtry wygładzające">
                        <StackPanel>
                            <Label Content="Rozmiar maski:" Style="{StaticResource SectionLabel}"/>
                            <ComboBox x:Name="CmbFilterSize" Width="80" Margin="2">
                                <ComboBoxItem Content="3x3" IsSelected="True"/>
                                <ComboBoxItem Content="5x5"/>
                                <ComboBoxItem Content="7x7"/>
                            </ComboBox>
                            <Button Content="Uśredniający" Click="Average_Click"/>
                            <Button Content="Gaussa"       Click="Gaussian_Click"/>
                            <Button Content="Wyostrzający" Click="Sharpen_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Wykrywanie krawędzi">
                        <StackPanel>
                            <Button Content="Krzyż Robertsa"  Click="Roberts_Click"/>
                            <Button Content="Operator Sobela" Click="Sobel_Click"/>
                            <Button Content="Laplasjan"        Click="Laplacian_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Filtr niestandardowy">
                        <StackPanel>
                            <Button Content="Definiuj kernel…" Click="CustomFilter_Click"/>
                            <TextBlock FontSize="10" TextWrapping="Wrap" MaxWidth="130" Margin="4,4,4,0"
                                       Text="Dowolna macierz wag – stosowana na bieżącym obrazie."/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Morfologia">
                        <StackPanel>
                            <Label Content="Rozmiar elem. strukturalnego:" Style="{StaticResource SectionLabel}"/>
                            <ComboBox x:Name="CmbMorphSize" Width="80" Margin="2">
                                <ComboBoxItem Content="3x3" IsSelected="True"/>
                                <ComboBoxItem Content="5x5"/>
                                <ComboBoxItem Content="7x7"/>
                            </ComboBox>
                            <Button Content="Erozja"    Click="Erode_Click"/>
                            <Button Content="Dylatacja" Click="Dilate_Click"/>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
